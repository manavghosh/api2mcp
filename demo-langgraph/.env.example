# ─────────────────────────────────────────────────────────────────────────────
#  LLM Provider Configuration
#  Pick ONE provider, set the matching API key, then run: cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Provider: anthropic | openai | google  (default: anthropic)
LLM_PROVIDER=anthropic

# Model name — leave blank to use the provider's default smart model:
#   anthropic  →  claude-opus-4-6
#   openai     →  gpt-4o
#   google     →  gemini-2.0-flash
# LLM_MODEL=claude-opus-4-6

# Sampling temperature 0.0–2.0  (0 = deterministic, better for demos)
# LLM_TEMPERATURE=0

# ─────────────────────────────────────────────────────────────────────────────
#  API Keys — uncomment and fill in the one that matches LLM_PROVIDER
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic  →  https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI     →  https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-...

# Google     →  https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=AIza...

# ─────────────────────────────────────────────────────────────────────────────
#  Server URLs — change only if you modified the default ports
# ─────────────────────────────────────────────────────────────────────────────

TASK_API_URL=http://localhost:8080
NOTES_API_URL=http://localhost:8081
TASK_MCP_URL=http://localhost:8090/mcp
NOTES_MCP_URL=http://localhost:8091/mcp
