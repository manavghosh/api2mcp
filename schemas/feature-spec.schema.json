{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api2mcp/api2mcp/main/schemas/feature-spec.schema.json",
  "title": "API2MCP Feature Specification",
  "description": "Schema for .spec/features/F*.md frontmatter (YAML between --- delimiters)",
  "type": "object",
  "required": ["id", "title", "phase", "priority", "effort", "status"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique feature identifier in the format F<phase>.<number> (e.g. F1.1, F6.4).",
      "pattern": "^F[0-9]+\\.[0-9]+$",
      "examples": ["F1.1", "F6.4"]
    },
    "title": {
      "type": "string",
      "description": "Human-readable feature title.",
      "minLength": 1,
      "examples": ["OpenAPI Parser", "VS Code Integration"]
    },
    "phase": {
      "type": "integer",
      "description": "Project phase number (1–7).",
      "minimum": 1,
      "maximum": 7
    },
    "priority": {
      "type": "string",
      "description": "Feature priority level.",
      "enum": ["P0", "P1", "P2", "P3"]
    },
    "effort": {
      "type": "string",
      "description": "Estimated implementation effort as a human-readable string.",
      "examples": ["1 week", "2 weeks", "3 days"]
    },
    "status": {
      "type": "string",
      "description": "Current implementation status.",
      "enum": ["planned", "in-progress", "completed", "blocked", "cancelled"]
    },
    "dependencies": {
      "type": "array",
      "description": "List of feature IDs that must be completed before this feature.",
      "items": {
        "type": "string",
        "pattern": "^F[0-9]+\\.[0-9]+$"
      },
      "examples": [["F1.1", "F1.2"]]
    }
  }
}
