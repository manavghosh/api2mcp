{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api2mcp/api2mcp/main/schemas/api2mcp-config.schema.json",
  "title": "API2MCP Configuration",
  "description": "Configuration schema for .api2mcp.yaml files",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "output": {
      "type": "string",
      "description": "Output directory for generated MCP server files.",
      "default": "generated",
      "examples": ["./generated", "./output", "dist/mcp"]
    },
    "host": {
      "type": "string",
      "description": "Host address for the MCP server.",
      "default": "127.0.0.1",
      "examples": ["127.0.0.1", "0.0.0.0", "localhost"]
    },
    "port": {
      "type": "integer",
      "description": "Port number for the MCP server.",
      "default": 8000,
      "minimum": 1,
      "maximum": 65535,
      "examples": [8000, 8080, 3000]
    },
    "transport": {
      "type": "string",
      "description": "Transport protocol for the MCP server. Use 'http' (Streamable HTTP, recommended) or 'stdio'.",
      "enum": ["http", "stdio"],
      "default": "http"
    },
    "log_level": {
      "type": "string",
      "description": "Logging level for the MCP server.",
      "enum": ["debug", "info", "warning", "error", "critical"],
      "default": "info"
    },
    "tls_warning": {
      "type": "boolean",
      "description": "Print a TLS warning when binding to 0.0.0.0 without TLS. Set false to silence.",
      "default": true
    },
    "auth": {
      "type": "object",
      "description": "Authentication provider configuration.",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["none", "api_key", "bearer", "basic", "oauth2"],
          "description": "Authentication type.",
          "default": "none"
        },
        "value": {
          "type": "string",
          "description": "Token or API key value. Supports ${ENV_VAR} interpolation."
        },
        "key_name": {
          "type": "string",
          "description": "Header/param/cookie name for api_key auth.",
          "default": "X-Api-Key"
        },
        "location": {
          "type": "string",
          "enum": ["header", "query", "cookie"],
          "description": "Where to place the api_key.",
          "default": "header"
        },
        "username": {
          "type": "string",
          "description": "Username for basic auth."
        },
        "password": {
          "type": "string",
          "description": "Password for basic auth. Supports ${ENV_VAR} interpolation."
        },
        "client_id": {
          "type": "string",
          "description": "OAuth2 client ID."
        },
        "client_secret": {
          "type": "string",
          "description": "OAuth2 client secret. Supports ${ENV_VAR} interpolation."
        },
        "token_url": {
          "type": "string",
          "description": "OAuth2 token endpoint URL."
        },
        "scopes": {
          "type": "array",
          "items": {"type": "string"},
          "description": "OAuth2 scopes to request."
        }
      }
    },
    "validation": {
      "type": "object",
      "description": "Input validation pipeline configuration.",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable input validation."
        },
        "max_payload_size": {
          "type": "integer",
          "default": 1048576,
          "description": "Maximum request payload size in bytes."
        },
        "max_string_length": {
          "type": "integer",
          "default": 10000,
          "description": "Maximum string field length."
        }
      }
    },
    "rate_limit": {
      "type": "object",
      "description": "Rate limiting configuration (token bucket per tool).",
      "additionalProperties": false,
      "properties": {
        "requests_per_second": {
          "type": "number",
          "default": 10,
          "description": "Sustained request rate (tokens/second)."
        },
        "burst": {
          "type": "integer",
          "default": 20,
          "description": "Maximum burst size (token bucket capacity)."
        },
        "max_retries": {
          "type": "integer",
          "default": 3,
          "description": "Maximum retry attempts when rate limited."
        }
      }
    },
    "cache": {
      "type": "object",
      "description": "Response cache configuration.",
      "additionalProperties": false,
      "properties": {
        "ttl": {
          "type": "integer",
          "default": 300,
          "description": "Default cache TTL in seconds."
        },
        "backend": {
          "type": "string",
          "enum": ["memory", "redis", "disk"],
          "default": "memory",
          "description": "Cache backend type."
        },
        "redis_url": {
          "type": "string",
          "default": "redis://localhost:6379",
          "description": "Redis connection URL (for backend: redis)."
        },
        "max_size": {
          "type": "integer",
          "default": 1000,
          "description": "Maximum number of cached entries (memory backend)."
        }
      }
    },
    "pool": {
      "type": "object",
      "description": "HTTP connection pool configuration.",
      "additionalProperties": false,
      "properties": {
        "max_connections": {
          "type": "integer",
          "default": 100,
          "description": "Maximum total pooled connections."
        },
        "max_keepalive": {
          "type": "integer",
          "default": 20,
          "description": "Maximum keep-alive connections per host."
        },
        "connect_timeout": {
          "type": "number",
          "default": 5.0,
          "description": "Connection timeout in seconds."
        },
        "read_timeout": {
          "type": "number",
          "default": 30.0,
          "description": "Read timeout in seconds."
        }
      }
    },
    "concurrency": {
      "type": "object",
      "description": "Concurrency limiting configuration.",
      "additionalProperties": false,
      "properties": {
        "max_concurrent": {
          "type": "integer",
          "default": 50,
          "description": "Maximum concurrent tool calls."
        },
        "timeout": {
          "type": "number",
          "default": 30.0,
          "description": "Wait timeout (seconds) when concurrency limit is reached."
        }
      }
    },
    "circuit_breaker": {
      "type": "object",
      "description": "Circuit breaker configuration.",
      "additionalProperties": false,
      "properties": {
        "failure_threshold": {
          "type": "integer",
          "default": 5,
          "description": "Consecutive failures before opening the circuit."
        },
        "recovery_timeout": {
          "type": "integer",
          "default": 60,
          "description": "Seconds before attempting recovery from OPEN state."
        },
        "success_threshold": {
          "type": "integer",
          "default": 2,
          "description": "Successes in HALF_OPEN state needed to close the circuit."
        }
      }
    },
    "plugins": {
      "type": "array",
      "items": {"type": "string"},
      "description": "List of plugin module paths to load at startup.",
      "examples": [["my_package.my_plugin", "another.plugin"]]
    },
    "secrets": {
      "type": "object",
      "description": "Secret manager configuration.",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["env", "vault", "aws", "keychain", "encrypted_file"],
          "default": "env",
          "description": "Secret provider backend."
        },
        "vault_url": {
          "type": "string",
          "description": "Vault server URL (provider: vault)."
        },
        "aws_region": {
          "type": "string",
          "description": "AWS region for Secrets Manager (provider: aws)."
        }
      }
    }
  }
}
