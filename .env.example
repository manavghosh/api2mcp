# API2MCP — Environment Variables Reference
# ==========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control.
# .env is listed in .gitignore; .env.example is safe to commit.

# ---------------------------------------------------------------------------
# LLM Provider (Orchestration / LangGraph agent)
# ---------------------------------------------------------------------------

# Which LLM provider to use for orchestration graphs.
# Options: anthropic (default), openai, google
LLM_PROVIDER=anthropic

# Anthropic (default) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# OpenAI (alternative) — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your_key_here

# Google Gemini (alternative) — https://aistudio.google.com/apikey
# GOOGLE_API_KEY=your_key_here

# ---------------------------------------------------------------------------
# API Credentials (used by example scripts and .api2mcp.yaml auth config)
# ---------------------------------------------------------------------------

# GitHub — https://github.com/settings/tokens
# Scopes needed: repo (issues read/write), read:user
GITHUB_TOKEN=ghp_your_token_here

# Stripe — https://dashboard.stripe.com/apikeys
# Use sk_test_... for testing, sk_live_... for production
STRIPE_API_KEY=sk_test_your_key_here

# OpenWeather (used in demo/ examples)
# OPENWEATHER_API_KEY=your_key_here

# Jira (used in multi-API orchestration examples)
# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_USER=you@example.com
# JIRA_API_TOKEN=your_token_here

# ---------------------------------------------------------------------------
# MCP Server Runtime
# ---------------------------------------------------------------------------

# Host and port for the generated MCP server (Streamable HTTP transport)
# Default: 127.0.0.1:8000
# API2MCP_HOST=0.0.0.0
# API2MCP_PORT=8000

# Transport type: streamable_http (production) or stdio (Claude Desktop / dev)
# API2MCP_TRANSPORT=streamable_http

# Log level: debug | info | warning | error | critical
# API2MCP_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# OAuth2 (optional — only needed if you use the OAuth2 auth provider)
# ---------------------------------------------------------------------------

# Redirect URI for OAuth2 Authorization Code flow
# The default works for local development
API2MCP_OAUTH2_REDIRECT_URI=http://localhost:8000/oauth/callback

# ---------------------------------------------------------------------------
# Caching (optional — only needed if you enable Redis caching)
# ---------------------------------------------------------------------------

# Redis connection URL for the Redis cache backend
# Default: redis://localhost:6379/0
# API2MCP_REDIS_URL=redis://localhost:6379/0

# Cache TTL in seconds (default: 300 = 5 minutes)
# API2MCP_CACHE_TTL=300

# ---------------------------------------------------------------------------
# Secret Management (optional backends)
# ---------------------------------------------------------------------------

# AWS Secrets Manager region (used when secret_backend = aws_secrets_manager)
# AWS_DEFAULT_REGION=us-east-1
# AWS credentials are picked up from ~/.aws/credentials or IAM role automatically

# HashiCorp Vault (used when secret_backend = vault)
# VAULT_ADDR=http://localhost:8200
# VAULT_TOKEN=your_vault_token_here
# VAULT_NAMESPACE=  # Enterprise only

# ---------------------------------------------------------------------------
# Observability (optional)
# ---------------------------------------------------------------------------

# OpenTelemetry collector endpoint
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Service name reported to the collector
# OTEL_SERVICE_NAME=api2mcp

# ---------------------------------------------------------------------------
# Development
# ---------------------------------------------------------------------------

# Disable telemetry/analytics (set to "1" to opt out)
# API2MCP_NO_TELEMETRY=1

# Enable debug mode (verbose logging, disable caching)
# API2MCP_DEBUG=1
