{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": [
    "tests/",
    "-v"
  ],
  "python.testing.unittestEnabled": false,

  "editor.formatOnSave": true,
  "editor.defaultFormatter": "charliermarsh.ruff",
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true
  },

  "yaml.schemas": {
    "./schemas/api2mcp-config.schema.json": [
      ".api2mcp.yaml",
      ".api2mcp.yml"
    ],
    "./schemas/feature-spec.schema.json": [
      ".spec/features/*.md"
    ]
  },
  "yaml.validate": true,
  "yaml.hover": true,
  "yaml.completion": true,

  "files.associations": {
    ".api2mcp.yaml": "yaml",
    ".api2mcp.yml": "yaml"
  },

  "search.exclude": {
    "**/.venv": true,
    "**/node_modules": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/dist": true,
    "**/build": true,
    "**/*.egg-info": true
  }
}
